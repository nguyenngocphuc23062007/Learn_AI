# Thông tin đăng nhập VNU mail (email @vnu.edu.vn hoặc @uet.vnu.edu.vn)
UET_EMAIL=youremail@vnu.edu.vn
UET_PASSWORD=your_password_here

# Chế độ chạy: "headless" (ẩn) hoặc "headed" (hiện trình duyệt)
BROWSER_MODE=headless

# Đường dẫn lưu session (không cần thay đổi)
SESSION_FILE=./session.json
OUTPUT_FILE=../public/lms-data.json
